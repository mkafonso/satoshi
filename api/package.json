  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  }
}
